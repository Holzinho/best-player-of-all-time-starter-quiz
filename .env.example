# =============================================================================
# Best Player of All Time Quiz – Environment Variables
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env. The Bearer token must stay server-side only.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Quiz API
# -----------------------------------------------------------------------------
# Base URL of the quiz API
QUIZ_API_BASE_URL=https://bestplayerofalltime.com

# Bearer token for API auth. Request at: https://bestplayerofalltime.com/token-anfragen
# This is NEVER exposed to the browser – only used by the internal /api/questions proxy.
QUIZ_API_TOKEN=your_api_token_here

# -----------------------------------------------------------------------------
# Optional: App defaults (client-safe, NEXT_PUBLIC_* is exposed to browser)
# -----------------------------------------------------------------------------
# App name shown on start screen
# NEXT_PUBLIC_APP_NAME=Best Player of All Time Quiz

# Default sport: football | basketball | padel
# NEXT_PUBLIC_DEFAULT_SPORT=football

# Default language: en | de | fr
# NEXT_PUBLIC_DEFAULT_LANG=en

# Default question count (1–50)
# NEXT_PUBLIC_DEFAULT_COUNT=10
